# Client Environment Variables Example
# Copy this file to .env and fill in your values

# API Base URL for backend server
VITE_API_BASE_URL=http://localhost:3000/api/users

# Server Base URL for static assets like images
VITE_SERVER_BASE_URL=http://localhost:3000

# LinkedIn OAuth URL
VITE_LINKEDIN_AUTH_URL=http://localhost:3000/api/auth/linkedin

# For production, change to your deployed server URL
# VITE_API_BASE_URL=https://your-production-api.com/api/users
# VITE_SERVER_BASE_URL=https://your-production-api.com
# VITE_LINKEDIN_AUTH_URL=https://your-production-api.com/api/auth/linkedin